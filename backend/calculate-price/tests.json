{
  "tests": [
    {
      "name": "OPTIONS CORS",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Донецк → Мариуполь (спецзона)",
      "method": "POST",
      "path": "/",
      "body": {"from": "Донецк", "to": "Мариуполь", "carClass": "standard"},
      "expectedStatus": 200,
      "expectedBody": {"has_special_zone": true, "source": "osrm"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Москва → Ростов-на-Дону (обычный маршрут)",
      "method": "POST",
      "path": "/",
      "body": {"from": "Москва", "to": "Ростов-на-Дону", "carClass": "standard"},
      "expectedStatus": 200,
      "expectedBody": {"has_special_zone": false, "km_special": 0, "source": "osrm"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Москва → Донецк (спецзона)",
      "method": "POST",
      "path": "/",
      "body": {"from": "Москва", "to": "Донецк", "carClass": "standard"},
      "expectedStatus": 200,
      "expectedBody": {"has_special_zone": true, "source": "osrm"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Симферополь → Ялта (Крым, обычный тариф)",
      "method": "POST",
      "path": "/",
      "body": {"from": "Симферополь", "to": "Ялта", "carClass": "standard"},
      "expectedStatus": 200,
      "expectedBody": {"km_special": 0, "has_special_zone": false, "source": "osrm"},
      "bodyMatcher": "partial"
    }
  ]
}
